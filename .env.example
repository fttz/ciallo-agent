# Shared
APP_NAME=Ciallo Agent

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Model Gateway (Aliyun Bailian OpenAI-compatible)
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_API_KEY=your_api_key_here
MODEL_DEFAULT=qwen3.5-plus
MODEL_VISION_DEFAULT=qwen3.5-plus
MODEL_CONFIGS=qwen3.5-plus:Qwen3.5 Plus:text,vision;qwen-plus-latest:Qwen Plus Latest:text;qwen-turbo-latest:Qwen Turbo Latest:text;qwen-vl-max-latest:Qwen VL Max Latest:text,vision

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20
SESSION_STORE_PATH=./data/sessions.json

# Redis / Postgres placeholders for next iterations
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ciallo
POSTGRES_USER=ciallo
POSTGRES_PASSWORD=ciallo
REDIS_HOST=localhost
REDIS_PORT=6379

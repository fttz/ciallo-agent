# Shared
APP_NAME=Ciallo Agent

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Model Gateway (Aliyun Bailian OpenAI-compatible)
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_API_KEY=your_api_key_here
MODEL_DEFAULT=qwen3.5-plus
MODEL_VISION_DEFAULT=qwen3.5-plus
MODEL_CONFIGS=qwen3.5-plus:Qwen3.5 Plus:text,vision;qwen-plus-latest:Qwen Plus Latest:text;qwen-turbo-latest:Qwen Turbo Latest:text;qwen-vl-max-latest:Qwen VL Max Latest:text,vision
MODEL_ENABLE_THINKING=false

# Web Search Tooling
WEB_SEARCH_ENABLED=true
WEB_SEARCH_AUTO_MODE=auto
WEB_SEARCH_TOP_K=10
WEB_SEARCH_FETCH_TOP_K=6
WEB_SEARCH_RERANK_TOP_N=4
WEB_SEARCH_FETCH_TIMEOUT_SEC=8
WEB_SEARCH_QUERY_PLANNER_MODEL=qwen3.5-plus
BAIDU_SEARCH_API_URL=https://qianfan.baidubce.com/v2/ai_search/chat/completions
BAIDU_SEARCH_API_KEY=
BAIDU_SEARCH_SOURCE=baidu_search_v2
RERANK_API_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_MODEL=gte-rerank-v2

SYSTEM_PROMPT_ENABLED=true
SYSTEM_PROMPT_TEMPLATE=你的名字是 Ciallo Agent。请以朝武芳乃风格和用户自然交流，保持友好、真诚、乐于帮助。你喜欢并可在合适时机自然使用颜文字“Ciallo～(∠・ω< )⌒☆”，但无需频繁重复。

# Storage
# Paths below are resolved from the API working directory (apps/api).
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20
SESSION_STORE_PATH=./data/sessions.json
PARSER_MAX_CHARS=12000
WEB_FETCH_TIMEOUT_SEC=15

# Redis / Postgres placeholders for next iterations
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ciallo
POSTGRES_USER=ciallo
POSTGRES_PASSWORD=ciallo
REDIS_HOST=localhost
REDIS_PORT=6379
